# Dockerfile.workspace — Per-user cloud workspace.
#
# Each user gets their own isolated instance of this container.
# It runs:
#   - workspace-server: WebSocket ↔ terminal relay (Go)
#   - tmux: session persistence (close Telegram, come back, everything's there)
#   - same: persistent memory engine (SAME vault + MCP server)
#   - claude: AI coding agent (Claude Code CLI)
#
# The user's vault data lives on a persistent Fly volume at /data.
# If this container is destroyed and recreated, the vault survives.

# --- Build workspace-server ---
FROM golang:1.25-bookworm AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=1 GOOS=linux go build \
    -ldflags "-s -w" \
    -o /usr/local/bin/workspace-server \
    ./cmd/workspace-server/

# --- Build React terminal frontend ---
FROM node:22-bookworm-slim AS frontend

WORKDIR /src/web/app
COPY web/app/package.json web/app/package-lock.json* ./
RUN npm ci --legacy-peer-deps
COPY web/app/ ./
RUN npm run build

# --- Runtime ---
FROM debian:bookworm-slim

# System dependencies. Each one is here for a reason:
#   ca-certificates: HTTPS to Anthropic/OpenRouter APIs
#   tmux: session persistence across disconnects
#   curl: health checks, API calls from terminal
#   git: version control from Claude Code
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    tmux \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Node.js — required by Claude Code CLI.
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI.
RUN npm install -g @anthropic-ai/claude-code 2>/dev/null || \
    echo "Claude Code CLI not yet available on npm — will be installed manually"

# Workspace server binary.
COPY --from=builder /usr/local/bin/workspace-server /usr/local/bin/workspace-server

# The SAME binary is provided at deploy time (built from statelessagent repo).
# COPY same /usr/local/bin/same

# Terminal frontends.
# Legacy HTML fallback (single file).
COPY web/terminal/ /opt/workspace/web/terminal-fallback/
# React terminal frontend (built from web/app/).
COPY --from=frontend /src/web/app/dist/ /opt/workspace/web/terminal/

# Vault seed scripts — populate new workspaces based on user selection.
COPY workspace/seeds/ /workspace/seeds/

# Startup script — initializes vault, wires MCP, starts server.
COPY workspace/startup.sh /usr/local/bin/startup.sh
RUN chmod +x /usr/local/bin/startup.sh

# Non-root user with a real shell. tmux and Claude Code need this.
RUN groupadd -r workspace && \
    useradd -r -g workspace -m -d /home/workspace -s /bin/bash workspace

# Persistent volume mount point. Fly.io attaches the volume here.
RUN mkdir -p /data && chown -R workspace:workspace /data

# Claude Code config directory.
RUN mkdir -p /home/workspace/.claude && \
    chown -R workspace:workspace /home/workspace/.claude

# Shell config — sources API keys and shows welcome on first connect.
# Must come AFTER useradd (which creates the home dir with -m).
COPY workspace/bashrc /home/workspace/.bashrc
RUN chown workspace:workspace /home/workspace/.bashrc

# Environment. These are defaults — overridable at runtime.
ENV SAME_HOME=/data \
    VAULT_PATH=/data/vault \
    WEB_DIR=/opt/workspace/web/terminal \
    WORKSPACE_ADDR=:8080 \
    TERM=xterm-256color

USER workspace
WORKDIR /home/workspace

EXPOSE 8080

# The startup script handles vault init, MCP wiring, and server launch.
ENTRYPOINT ["/usr/local/bin/startup.sh"]
